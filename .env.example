# ─────────────────────────────────────────────────────────────────────────────
# Ethereum Wallet Tracker Bot — Environment Variables
# Copy this file to .env and fill in all values before running locally.
# On Railway, set these directly in the service's Variables tab.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ─────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Random secret used to secure the Telegram webhook endpoint.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_WEBHOOK_SECRET=

# Public base URL of this service (no trailing slash).
# On Railway this is your auto-assigned domain, e.g. https://aster-tracker.up.railway.app
WEBHOOK_BASE_URL=

# ── Alchemy ──────────────────────────────────────────────────────────────────
# API key from https://dashboard.alchemy.com/
ALCHEMY_API_KEY=

# Signing key displayed on the webhook page in the Alchemy Dashboard.
# Used to validate incoming webhook payloads.
ALCHEMY_WEBHOOK_SIGNING_KEY=

# The numeric webhook ID shown in the Alchemy Dashboard (e.g. "wh_abc123")
ALCHEMY_WEBHOOK_ID=

# Alchemy Auth Token for the management API (create at https://dashboard.alchemy.com/settings/api-keys)
# This is a DIFFERENT token from ALCHEMY_API_KEY — it's used to add/remove addresses
# from the webhook via PATCH /api/update-webhook-addresses
ALCHEMY_AUTH_TOKEN=

# Ethereum network — "mainnet" or "sepolia" for testing
ALCHEMY_NETWORK=mainnet

# ── OpenSea ──────────────────────────────────────────────────────────────────
# API key from https://docs.opensea.io/reference/request-an-api-key
# Required for the OpenSea Stream WebSocket and REST API fallback.
OPENSEA_API_KEY=

# ── Database ─────────────────────────────────────────────────────────────────
# Full async PostgreSQL connection string.
# Railway auto-injects this if you add a Postgres plugin to the project.
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
